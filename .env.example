# 基本配置
PORT=8080
PASSWORD=
ADMINPASSWORD=
DEBUG=false

# CORS 配置
CORS_ORIGIN=*

# 请求配置
REQUEST_TIMEOUT=5000
MAX_RETRIES=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36

# 缓存配置
CACHE_MAX_AGE=1d

# 安全配置
BLOCKED_HOSTS=localhost,127.0.0.1,0.0.0.0,::1
# 说明：内网/保留网段已由 lib/security.mjs 通过 DNS 解析 + CIDR 自动拦截，
# BLOCKED_IP_PREFIXES 已废弃；如需追加自定义域名黑名单，请写入 BLOCKED_HOSTS。
FILTERED_HEADERS=content-security-policy,cookie,set-cookie,x-frame-options,access-control-allow-origin

# 服务端代理鉴权（强烈建议公网部署时开启，杜绝开放代理被滥用）
# 开启后 /proxy 需要先通过 POST /api/login 获取会话 Cookie
PROXY_AUTH=false
# 会话有效期（毫秒），默认 90 天
SESSION_TTL_MS=7776000000
# 会话签名密钥；留空则自动从密码哈希派生
SESSION_SECRET=

# 代理限流（单实例内存版；0 表示关闭）
RATE_LIMIT_MAX=0
RATE_LIMIT_WINDOW_MS=60000
